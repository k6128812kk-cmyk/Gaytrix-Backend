# =======================================================
# GayTrix Backend — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# =======================================================

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=8963089491:AAFVP5rxslNzkmVjbv42FH0tOURzbqOkeCw

# Super Admin — only this Telegram account gets super_admin role
SUPER_ADMIN_TELEGRAM_ID=528269003
SUPER_ADMIN_USERNAME=k54lid

# PostgreSQL connection (Railway provides this automatically)
DATABASE_URL=postgresql://postgres:password@localhost:5432/gaytrix

# JWT secret — generate a random 64-char string
JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_64_chars

# Frontend URL (your Netlify URL) — for CORS
FRONTEND_URL=https://your-app.netlify.app

# Port
PORT=3000

# File upload directory (local) or set to 's3' for production
UPLOAD_STORAGE=local
UPLOAD_DIR=./uploads
